<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Blinc renders with WebGPU/Vulkan; require GLES 3.0 as a floor. -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <application
        android:allowBackup="true"
        android:label="${appLabel}"
        android:hardwareAccelerated="true"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">

        <!-- Pure NativeActivity: the `android-activity` `native-activity`
             feature provides ANativeActivity_onCreate and calls our
             `android_main`. `lib_name` matches the cdylib name
             (libelpis_android.so). No Java/Kotlin Activity needed. -->
        <activity
            android:name="android.app.NativeActivity"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|density"
            android:exported="true">

            <meta-data
                android:name="android.app.lib_name"
                android:value="elpis_android" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
